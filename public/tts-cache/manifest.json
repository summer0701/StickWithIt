{
  "voice": "ko-KR-SunHiNeural",
  "items": {
    "start_001": {
      "category": "start",
      "text": "달리기 시작. 오늘도 과거의 너와 경쟁한다.",
      "file": "/tts-cache/start_001.mp3"
    },
    "start_002": {
      "category": "start",
      "text": "좋아. 처음 1분은 힘을 아끼면서 리듬부터 잡자.",
      "file": "/tts-cache/start_002.mp3"
    },
    "start_003": {
      "category": "start",
      "text": "출발했어. 끝까지 버텨라.",
      "file": "/tts-cache/start_003.mp3"
    },
    "warmup_001": {
      "category": "warmup",
      "text": "좋아. 지금 리듬 괜찮아.",
      "file": "/tts-cache/warmup_001.mp3"
    },
    "warmup_002": {
      "category": "warmup",
      "text": "호흡은 길게, 발은 가볍게.",
      "file": "/tts-cache/warmup_002.mp3"
    },
    "warmup_003": {
      "category": "warmup",
      "text": "초반은 차분하게. 몸을 천천히 깨우자.",
      "file": "/tts-cache/warmup_003.mp3"
    },
    "ahead_001": {
      "category": "ahead",
      "text": "어제의 너보다 앞서고 있어. 이 페이스 유지해.",
      "file": "/tts-cache/ahead_001.mp3"
    },
    "ahead_002": {
      "category": "ahead",
      "text": "조금 앞서고 있어. 지금 흐름 좋아.",
      "file": "/tts-cache/ahead_002.mp3"
    },
    "ahead_003": {
      "category": "ahead",
      "text": "꽤 앞서고 있어. 욕심내지 말고 유지하자.",
      "file": "/tts-cache/ahead_003.mp3"
    },
    "behind_001": {
      "category": "behind",
      "text": "조금 뒤처졌어. 호흡부터 다시 잡자.",
      "file": "/tts-cache/behind_001.mp3"
    },
    "behind_002": {
      "category": "behind",
      "text": "아직 충분히 따라갈 수 있어.",
      "file": "/tts-cache/behind_002.mp3"
    },
    "behind_003": {
      "category": "behind",
      "text": "괜찮아. 리듬을 되찾으면 다시 붙을 수 있어.",
      "file": "/tts-cache/behind_003.mp3"
    },
    "close_001": {
      "category": "close",
      "text": "거의 따라잡았어. 지금부터 집중하자.",
      "file": "/tts-cache/close_001.mp3"
    },
    "close_002": {
      "category": "close",
      "text": "차이가 거의 없어. 한 번만 더 밀어붙여.",
      "file": "/tts-cache/close_002.mp3"
    },
    "close_003": {
      "category": "close",
      "text": "바로 앞이야. 흔들리지 말고 따라가자.",
      "file": "/tts-cache/close_003.mp3"
    },
    "halfway_001": {
      "category": "halfway",
      "text": "절반을 넘었어. 지금부터 버티는 사람이 이긴다.",
      "file": "/tts-cache/halfway_001.mp3"
    },
    "halfway_002": {
      "category": "halfway",
      "text": "반 이상 왔어. 페이스를 안정적으로 가져가자.",
      "file": "/tts-cache/halfway_002.mp3"
    },
    "halfway_003": {
      "category": "halfway",
      "text": "중간 지점 통과. 아직 힘은 남아 있어.",
      "file": "/tts-cache/halfway_003.mp3"
    },
    "one_km_left_001": {
      "category": "one_km_left",
      "text": "마지막 1킬로미터야. 지금부터가 진짜 승부다.",
      "file": "/tts-cache/one_km_left_001.mp3"
    },
    "one_km_left_002": {
      "category": "one_km_left",
      "text": "1킬로미터 남았어. 여기서 포기하면 안 돼.",
      "file": "/tts-cache/one_km_left_002.mp3"
    },
    "one_km_left_003": {
      "category": "one_km_left",
      "text": "마지막 구간이야. 자세 무너지지 않게 버텨.",
      "file": "/tts-cache/one_km_left_003.mp3"
    },
    "finish_push_001": {
      "category": "finish_push",
      "text": "끝이 보인다. 마지막까지 밀어붙여.",
      "file": "/tts-cache/finish_push_001.mp3"
    },
    "finish_push_002": {
      "category": "finish_push",
      "text": "지금부터 마무리야. 한 걸음만 더 버텨.",
      "file": "/tts-cache/finish_push_002.mp3"
    },
    "finish_push_003": {
      "category": "finish_push",
      "text": "마지막 힘을 꺼낼 시간이야.",
      "file": "/tts-cache/finish_push_003.mp3"
    },
    "personal_record_001": {
      "category": "personal_record",
      "text": "개인 기록이 보인다. 이 페이스면 충분해.",
      "file": "/tts-cache/personal_record_001.mp3"
    },
    "personal_record_002": {
      "category": "personal_record",
      "text": "오늘 기록 좋다. 끝까지 유지해.",
      "file": "/tts-cache/personal_record_002.mp3"
    },
    "personal_record_003": {
      "category": "personal_record",
      "text": "새 기록에 가까워지고 있어. 흔들리지 마.",
      "file": "/tts-cache/personal_record_003.mp3"
    },
    "tired_001": {
      "category": "tired",
      "text": "힘든 구간이야. 어깨 힘 빼고 호흡을 길게 가져가.",
      "file": "/tts-cache/tired_001.mp3"
    },
    "tired_002": {
      "category": "tired",
      "text": "다리가 무거워도 리듬은 놓치지 마.",
      "file": "/tts-cache/tired_002.mp3"
    },
    "tired_003": {
      "category": "tired",
      "text": "지금 힘든 건 정상이다. 한 번 더 버텨.",
      "file": "/tts-cache/tired_003.mp3"
    },
    "slow_down_001": {
      "category": "slow_down",
      "text": "호흡이 거칠면 살짝 늦춰도 괜찮아.",
      "file": "/tts-cache/slow_down_001.mp3"
    },
    "slow_down_002": {
      "category": "slow_down",
      "text": "무리하지 말고 자세부터 다시 세우자.",
      "file": "/tts-cache/slow_down_002.mp3"
    },
    "slow_down_003": {
      "category": "slow_down",
      "text": "속도보다 완주가 먼저야. 안정적으로 가자.",
      "file": "/tts-cache/slow_down_003.mp3"
    },
    "completed_001": {
      "category": "completed",
      "text": "러닝 완료. 오늘도 끝까지 버텼다.",
      "file": "/tts-cache/completed_001.mp3"
    },
    "completed_002": {
      "category": "completed",
      "text": "끝냈어. 오늘의 너는 어제보다 강해졌다.",
      "file": "/tts-cache/completed_002.mp3"
    },
    "completed_003": {
      "category": "completed",
      "text": "완주 성공. 이 기록은 네가 만든 거야.",
      "file": "/tts-cache/completed_003.mp3"
    }
  }
}
